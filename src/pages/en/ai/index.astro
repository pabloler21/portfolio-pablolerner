---
import RoleLayout from '../../../layouts/RoleLayout.astro';
import ProjectCard from '../../../components/ui/ProjectCard.astro';

const projects = [
  {
    name: 'Iris — Personal AI Assistant',
    desc: '24/7 assistant on homelab Linux — Discord interface, RAG over personal docs (Qdrant), automated weekly AI digest curated from 8+ RSS feeds',
    stack: ['Python', 'Qdrant', 'OpenAI', 'Discord', 'systemd'],
    status: 'ACTIVE',
    featured: true,
    github: 'https://github.com/pabloler21/Iris',
  },
  {
    name: 'CV Evaluator + Job Board',
    desc: 'ATS resume analyzer and remote job board — FastAPI backend, LangChain orchestration, Claude Haiku for scoring. Deployed on Render with live demo.',
    stack: ['FastAPI', 'LangChain', 'Claude API', 'Python'],
    status: 'DEPLOYED',
    github: 'https://github.com/pabloler21/bot_curriculum',
    demo: 'https://bot-curriculum-1.onrender.com',
  },
  {
    name: 'Team Agent Ops — Hermes',
    desc: 'Multi-agent team bot: Hermes LLM + BullMQ/Redis durable task queue + Discord interface + GitHub MCP integration, replacing fragile n8n workflows',
    stack: ['Python', 'Hermes Agent', 'BullMQ', 'Redis', 'Discord', 'MCP'],
    status: 'DEPLOYED',
    github: 'https://github.com/pabloler21/prbot-hermes',
  },
  {
    name: 'Python TutorBot',
    desc: 'LangChain agentic tutor with tool-calling: on-demand Stack Overflow search, conversational memory, Gradio chat interface',
    stack: ['Python', 'LangChain', 'Gradio'],
    status: 'BUILT',
    github: 'https://github.com/pabloler21/TutorBot',
  },
  {
    name: 'Obsidian Job Tracker',
    desc: 'Claude Code slash commands for structured job-search tracking inside Obsidian vaults — custom AI-powered workflow tooling',
    stack: ['Claude Code', 'Markdown', 'Obsidian'],
    status: 'TOOLING',
    github: 'https://github.com/pabloler21/obsidian-job-tracker',
  },
  {
    name: 'Second Brain Challenge',
    desc: 'AI agent that processes WhatsApp bank transfer receipt images — built for Galo\'s Second Brain workshop, agentic document parsing pipeline',
    stack: ['Python', 'AI Agents'],
    status: 'BUILT',
    github: 'https://github.com/pabloler21/workshop-challenge',
  },
] as const;
---

<RoleLayout title="AI Engineer — Records" lang="en" role="ai"
  description="Pablo Lerner — AI Engineer: LLM systems, multi-agent pipelines, RAG, FastAPI services.">

  <h2 class="role-title">AI ENGINEER</h2>
  <p class="role-sub sys-text">UNIT PROFILE · ACCESS LEVEL: OPEN · RECORDS: 6</p>

  <div class="stats">
    <div class="stat-row">
      <span class="stat-label">SPECIALIZATION</span>
      <span>LLM · Multi-agent · RAG · Tool-calling</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">FLAGSHIP</span>
      <span class="accent">IRIS — PERSONAL AI ASSISTANT</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">TOOLS</span>
      <span>Python · LangChain · FastAPI · Claude API · Qdrant</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">STATUS</span>
      <span class="accent">ACTIVE · OPEN TO WORK</span>
    </div>
  </div>

  <p class="archive-label sys-text">MEMORY ARCHIVE · <span class="accent">6 FILES FOUND</span></p>

  <ul class="project-list">
    {projects.map(p => <ProjectCard {...p} />)}
  </ul>
</RoleLayout>

<style>
  .role-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 0.2rem;
  }

  .role-sub {
    padding-bottom: 0.8rem;
    border-bottom: var(--border);
    font-size: 0.6rem;
    margin-bottom: 1rem;
  }

  .stats { margin-bottom: 1.2rem; }

  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.3rem 0;
    border-bottom: 1px dotted var(--ink);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
  }

  .stat-label {
    color: var(--sand-dim);
    flex-shrink: 0;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
  }

  .accent { color: var(--accent); }

  .archive-label {
    font-size: 0.6rem;
    margin-bottom: 0.4rem;
  }

  .project-list { list-style: none; display: flex; flex-direction: column; gap: 0.3rem; }
</style>
