---
import RoleLayout from '../../../layouts/RoleLayout.astro';
import ProjectCard from '../../../components/ui/ProjectCard.astro';

const projects = [
  {
    name: 'FraudSense AI — Fraud Risk Analytics',
    desc: 'End-to-end fraud detection: SQL pattern analysis on 1.85M transactions → EDA → ML baseline → Power BI dashboard → AI explanation API (FastAPI + Claude Haiku)',
    stack: ['Python', 'PostgreSQL', 'scikit-learn', 'Power BI', 'FastAPI', 'Claude API'],
    status: 'FLAGSHIP',
    featured: true,
    github: 'https://github.com/pabloler21/fraud-risk-analytics',
  },
  {
    name: 'Credit Scoring — Give Me Some Credit',
    desc: 'Complete credit scoring pipeline: EDA, ETL, feature selection, multiple ML models, and a Streamlit app — Kaggle competition dataset',
    stack: ['Python', 'scikit-learn', 'Streamlit', 'Pandas', 'XGBoost'],
    status: 'BUILT',
    github: 'https://github.com/pabloler21/credit-scoring-give-me-some-credit',
  },
  {
    name: 'Adventure Works Financial Dashboard',
    desc: 'Financial analysis and interactive Power BI dashboard on Adventure Works: revenue, costs, margins, and commercial performance across product lines',
    stack: ['Power BI', 'DAX', 'Data Modeling'],
    status: 'BUILT',
    github: 'https://github.com/pabloler21/adventure-works-financial-dashboard',
  },
  {
    name: 'SQL Fast Food Data Analysis',
    desc: 'Relational database design and analytical queries for a fast food ordering system — data modeling, multi-table JOINs, aggregation functions',
    stack: ['SQL', 'T-SQL', 'Data Modeling'],
    status: 'BUILT',
    github: 'https://github.com/pabloler21/sql-fast-food-data-analysis',
  },
  {
    name: 'Google Sheets Sales Analysis',
    desc: 'Financial analysis and dashboards built in Google Sheets: sales performance, cost tracking, and profit margin visualization',
    stack: ['Google Sheets', 'Data Viz'],
    status: 'BUILT',
    github: 'https://github.com/pabloler21/google-sheets-sales-analysis',
  },
  {
    name: 'Smart Inventory — Group Project',
    desc: 'Predictive analytics for inventory management — group project (6 members); Pablo\'s role: Predictive Analyst',
    stack: ['Python', 'Pandas', 'Data Analytics'],
    status: 'BUILT',
    github: 'https://github.com/pabloler21/Proyecto_Final_Grupo_2',
  },
  {
    name: 'Byogenesis Lab Location Analysis',
    desc: 'Python/Pandas analysis to determine optimal countries for lab expansion using 2021 COVID-19 case data and vaccination correlation modeling',
    stack: ['Python', 'Pandas', 'NumPy', 'Matplotlib', 'Seaborn'],
    status: 'BUILT',
    github: 'https://github.com/pabloler21/proyecto_integrador_m4_python',
  },
] as const;
---

<RoleLayout title="Data Analyst — Records" lang="en" role="risk"
  description="Pablo Lerner — Data Analyst: fraud detection, credit scoring, SQL, Power BI dashboards.">

  <h2 class="role-title">DATA ANALYST</h2>
  <p class="role-sub sys-text">UNIT PROFILE · ACCESS LEVEL: OPEN · RECORDS: 7</p>

  <div class="stats">
    <div class="stat-row">
      <span class="stat-label">SPECIALIZATION</span>
      <span>Credit Risk · Fraud Detection · BI Dashboards · SQL</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">FLAGSHIP</span>
      <span class="accent">FRAUDSENSE AI — FRAUD RISK ANALYTICS</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">TOOLS</span>
      <span>Python · SQL · Power BI · scikit-learn · FastAPI</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">STATUS</span>
      <span class="accent">ACTIVE · OPEN TO WORK</span>
    </div>
  </div>

  <p class="archive-label sys-text">MEMORY ARCHIVE · <span class="accent">7 FILES FOUND</span></p>

  <ul class="project-list">
    {projects.map(p => <ProjectCard {...p} />)}
  </ul>
</RoleLayout>

<style>
  .role-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 0.2rem;
  }

  .role-sub {
    padding-bottom: 0.8rem;
    border-bottom: var(--border);
    font-size: 0.6rem;
    margin-bottom: 1rem;
  }

  .stats { margin-bottom: 1.2rem; }

  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.3rem 0;
    border-bottom: 1px dotted var(--ink);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
  }

  .stat-label {
    color: var(--sand-dim);
    flex-shrink: 0;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
  }

  .accent { color: var(--accent); }

  .archive-label {
    font-size: 0.6rem;
    margin-bottom: 0.4rem;
  }

  .project-list { list-style: none; display: flex; flex-direction: column; gap: 0.3rem; }
</style>
