---
import RoleLayout from '../../../layouts/RoleLayout.astro';
import ProjectCard from '../../../components/ui/ProjectCard.astro';

const projects = [
  {
    name: 'Iris — Asistente de IA Personal',
    desc: 'Asistente disponible 24/7 en homelab Linux — interfaz por Discord, RAG sobre documentos personales (Qdrant), digest semanal automatizado de noticias de IA',
    stack: ['Python', 'Qdrant', 'OpenAI', 'Discord', 'systemd'],
    status: 'ACTIVO',
    featured: true,
    github: 'https://github.com/pabloler21/Iris',
  },
  {
    name: 'CV Evaluator + Tablero de Empleos',
    desc: 'Analizador de CVs tipo ATS y tablero de empleos remotos — backend con FastAPI, orquestación con LangChain, scoring con Claude Haiku. Desplegado en Render con demo en vivo.',
    stack: ['FastAPI', 'LangChain', 'Claude API', 'Python'],
    status: 'DEPLOYED',
    github: 'https://github.com/pabloler21/bot_curriculum',
    demo: 'https://bot-curriculum-1.onrender.com',
  },
  {
    name: 'Team Agent Ops — Hermes',
    desc: 'Bot multi-agente de equipo: Hermes LLM + cola durable BullMQ/Redis + interfaz Discord + integración GitHub via MCP — reemplazando workflows de n8n',
    stack: ['Python', 'Hermes Agent', 'BullMQ', 'Redis', 'Discord', 'MCP'],
    status: 'DEPLOYED',
    github: 'https://github.com/pabloler21/prbot-hermes',
  },
  {
    name: 'Python TutorBot',
    desc: 'Tutor agéntico con LangChain y tool-calling: búsqueda en Stack Overflow bajo demanda, memoria conversacional, interfaz de chat en Gradio',
    stack: ['Python', 'LangChain', 'Gradio'],
    status: 'COMPLETADO',
    github: 'https://github.com/pabloler21/TutorBot',
  },
  {
    name: 'Obsidian Job Tracker',
    desc: 'Slash commands de Claude Code para rastrear búsqueda laboral de forma estructurada dentro de Obsidian — tooling personalizado con IA',
    stack: ['Claude Code', 'Markdown', 'Obsidian'],
    status: 'HERRAMIENTA',
    github: 'https://github.com/pabloler21/obsidian-job-tracker',
  },
  {
    name: 'Second Brain Challenge',
    desc: 'Agente que procesa imágenes de comprobantes de transferencia por WhatsApp — solución para el workshop de Second Brain de Galo, pipeline agéntico de análisis documental',
    stack: ['Python', 'AI Agents'],
    status: 'COMPLETADO',
    github: 'https://github.com/pabloler21/workshop-challenge',
  },
] as const;
---

<RoleLayout title="AI Engineer — Registros" lang="es" role="ai"
  description="Pablo Lerner — AI Engineer: sistemas LLM, pipelines multi-agente, RAG, servicios FastAPI.">

  <h2 class="role-title">AI ENGINEER</h2>
  <p class="role-sub sys-text">PERFIL DE UNIDAD · ACCESO: ABIERTO · REGISTROS: 6</p>

  <div class="stats">
    <div class="stat-row">
      <span class="stat-label">ESPECIALIZACIÓN</span>
      <span>LLM · Multi-agente · RAG · Tool-calling</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">PROYECTO ESTRELLA</span>
      <span class="accent">IRIS — ASISTENTE DE IA PERSONAL</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">HERRAMIENTAS</span>
      <span>Python · LangChain · FastAPI · Claude API · Qdrant</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">ESTADO</span>
      <span class="accent">ACTIVO · DISPONIBLE</span>
    </div>
  </div>

  <p class="archive-label sys-text">ARCHIVO DE MEMORIA · <span class="accent">6 ARCHIVOS ENCONTRADOS</span></p>

  <ul class="project-list">
    {projects.map(p => <ProjectCard {...p} />)}
  </ul>
</RoleLayout>

<style>
  .role-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 0.2rem;
  }

  .role-sub {
    padding-bottom: 0.8rem;
    border-bottom: var(--border);
    font-size: 0.6rem;
    margin-bottom: 1rem;
  }

  .stats { margin-bottom: 1.2rem; }

  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.3rem 0;
    border-bottom: 1px dotted var(--ink);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
  }

  .stat-label {
    color: var(--sand-dim);
    flex-shrink: 0;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
  }

  .accent { color: var(--accent); }

  .archive-label {
    font-size: 0.6rem;
    margin-bottom: 0.4rem;
  }

  .project-list { list-style: none; display: flex; flex-direction: column; gap: 0.3rem; }
</style>
