---
import RoleLayout from '../../../layouts/RoleLayout.astro';
import ProjectCard from '../../../components/ui/ProjectCard.astro';
import { aiProjects } from '../../../data/projects';

const lang = 'es';
const cards = aiProjects.map(p => ({
  name:     p.es.name,
  desc:     p.es.problem,
  outcome:  p.es.outcome || undefined,
  stack:    p.stack,
  status:   p.statusEs ?? p.status,
  featured: p.featured,
  github:   p.github,
  demo:     p.demo,
}));
---

<RoleLayout title="AI Engineer — Registros" lang="es" role="ai"
  description="Pablo Lerner — AI Engineer: sistemas LLM, pipelines multi-agente, RAG, servicios FastAPI.">

  <div class="role-header">
    <h2 class="role-title">AI ENGINEER</h2>
    <span class="role-badge">ESPECIALIZACIÓN</span>
  </div>
  <p class="role-sub sys-text">PERFIL DE UNIDAD · ACCESO: ABIERTO · REGISTROS: {cards.length}</p>

  <div class="stats">
    <div class="stat-row">
      <span class="stat-label">ESPECIALIZACIÓN</span>
      <span>LLM · Multi-agente · RAG · Tool-calling</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">PROYECTO ESTRELLA</span>
      <span class="accent-bright">IRIS — Asistente de IA Personal · 1.2M vectores indexados</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">HERRAMIENTAS</span>
      <span>Python · LangChain · FastAPI · Claude API · Qdrant</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">ESTADO</span>
      <span class="accent-bright">ACTIVO · DISPONIBLE</span>
    </div>
  </div>

  <p class="archive-label sys-text">ARCHIVO DE MEMORIA · <span class="accent-bright">{cards.length} ARCHIVOS ENCONTRADOS</span></p>

  <ul class="project-list">
    {cards.map(p => <ProjectCard {...p} />)}
  </ul>
</RoleLayout>

<style>
  .role-header {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    margin-bottom: 0.3rem;
    flex-wrap: wrap;
  }

  .role-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--sand);
  }

  .role-badge {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--accent);
    color: var(--accent);
  }

  .role-sub {
    padding-bottom: 0.8rem;
    border-bottom: var(--border);
    font-size: 0.6rem;
    margin-bottom: 1rem;
  }

  .stats { margin-bottom: 1rem; }

  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.35rem 0;
    border-bottom: 1px dotted var(--ink);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
  }

  .stat-label {
    color: var(--sand-dim);
    flex-shrink: 0;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
  }

  .accent-bright { color: var(--accent-bright); }

  .archive-label {
    font-size: 0.6rem;
    margin-bottom: 0.6rem;
  }

  .project-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
</style>
