---
import RoleLayout from '../../../layouts/RoleLayout.astro';
import ProjectCard from '../../../components/ui/ProjectCard.astro';

const projects = [
  {
    name: 'FraudSense AI — Análisis de Riesgo de Fraude',
    desc: 'Detección de fraude end-to-end: análisis SQL sobre 1,85M transacciones → EDA → baseline de ML → dashboard Power BI → API de explicaciones con FastAPI y Claude Haiku',
    stack: ['Python', 'PostgreSQL', 'scikit-learn', 'Power BI', 'FastAPI', 'Claude API'],
    status: 'DESTACADO',
    featured: true,
    github: 'https://github.com/pabloler21/fraud-risk-analytics',
  },
  {
    name: 'Credit Scoring — Give Me Some Credit',
    desc: 'Pipeline completo de credit scoring: EDA, ETL, selección de variables, múltiples modelos de ML y app en Streamlit — dataset de competencia Kaggle',
    stack: ['Python', 'scikit-learn', 'Streamlit', 'Pandas', 'XGBoost'],
    status: 'COMPLETADO',
    github: 'https://github.com/pabloler21/credit-scoring-give-me-some-credit',
  },
  {
    name: 'Adventure Works — Dashboard Financiero',
    desc: 'Análisis financiero e dashboard interactivo en Power BI sobre Adventure Works: ingresos, costos, márgenes y performance comercial por línea de producto',
    stack: ['Power BI', 'DAX', 'Modelado de Datos'],
    status: 'COMPLETADO',
    github: 'https://github.com/pabloler21/adventure-works-financial-dashboard',
  },
  {
    name: 'Análisis SQL — Fast Food',
    desc: 'Diseño de base de datos relacional y consultas analíticas para un sistema de pedidos de fast food — modelado de datos, JOINs multi-tabla, funciones de agregación',
    stack: ['SQL', 'T-SQL', 'Modelado de Datos'],
    status: 'COMPLETADO',
    github: 'https://github.com/pabloler21/sql-fast-food-data-analysis',
  },
  {
    name: 'Análisis de Ventas en Google Sheets',
    desc: 'Análisis financiero y dashboards construidos en Google Sheets: seguimiento de ventas, costos y visualización de márgenes de ganancia',
    stack: ['Google Sheets', 'Visualización de Datos'],
    status: 'COMPLETADO',
    github: 'https://github.com/pabloler21/google-sheets-sales-analysis',
  },
  {
    name: 'Inventario Inteligente — Proyecto Grupal',
    desc: 'Analítica predictiva para gestión de inventario — proyecto grupal (6 integrantes); rol de Pablo: Analista Predictivo',
    stack: ['Python', 'Pandas', 'Data Analytics'],
    status: 'COMPLETADO',
    github: 'https://github.com/pabloler21/Proyecto_Final_Grupo_2',
  },
  {
    name: 'Análisis de Localización — Byogenesis',
    desc: 'Análisis Python/Pandas para determinar los mejores países para apertura de laboratorios usando datos de COVID-19 2021 y correlación con vacunación',
    stack: ['Python', 'Pandas', 'NumPy', 'Matplotlib', 'Seaborn'],
    status: 'COMPLETADO',
    github: 'https://github.com/pabloler21/proyecto_integrador_m4_python',
  },
] as const;
---

<RoleLayout title="Data Analyst — Registros" lang="es" role="risk"
  description="Pablo Lerner — Data Analyst: detección de fraude, credit scoring, SQL, dashboards Power BI.">

  <h2 class="role-title">DATA ANALYST</h2>
  <p class="role-sub sys-text">PERFIL DE UNIDAD · ACCESO: ABIERTO · REGISTROS: 7</p>

  <div class="stats">
    <div class="stat-row">
      <span class="stat-label">ESPECIALIZACIÓN</span>
      <span>Riesgo Crediticio · Detección de Fraude · BI Dashboards · SQL</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">PROYECTO ESTRELLA</span>
      <span class="accent">FRAUDSENSE AI — ANÁLISIS DE RIESGO DE FRAUDE</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">HERRAMIENTAS</span>
      <span>Python · SQL · Power BI · scikit-learn · FastAPI</span>
    </div>
    <div class="stat-row">
      <span class="stat-label">ESTADO</span>
      <span class="accent">ACTIVO · DISPONIBLE</span>
    </div>
  </div>

  <p class="archive-label sys-text">ARCHIVO DE MEMORIA · <span class="accent">7 ARCHIVOS ENCONTRADOS</span></p>

  <ul class="project-list">
    {projects.map(p => <ProjectCard {...p} />)}
  </ul>
</RoleLayout>

<style>
  .role-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 0.2rem;
  }

  .role-sub {
    padding-bottom: 0.8rem;
    border-bottom: var(--border);
    font-size: 0.6rem;
    margin-bottom: 1rem;
  }

  .stats { margin-bottom: 1.2rem; }

  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.3rem 0;
    border-bottom: 1px dotted var(--ink);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
  }

  .stat-label {
    color: var(--sand-dim);
    flex-shrink: 0;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
  }

  .accent { color: var(--accent); }

  .archive-label {
    font-size: 0.6rem;
    margin-bottom: 0.4rem;
  }

  .project-list { list-style: none; display: flex; flex-direction: column; gap: 0.3rem; }
</style>
