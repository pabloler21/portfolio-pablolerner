---
interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;

const now = new Date();
const sysDate = `${now.getFullYear()}.${String(now.getMonth() + 1).padStart(2, '0')}.${String(now.getDate()).padStart(2, '0')}`;
---

<footer class="status-bar">
  <div class="controls">
    <span class="control"><span class="key">◆</span>SELECT</span>
    <span class="control"><span class="key">↵</span>CONFIRM</span>
    <span class="control"><span class="key">ESC</span>BACK</span>
  </div>

  <div class="lang-toggle">
    <a href="/en/" class:list={['lang-btn', { active: lang === 'en' }]} aria-label="English">EN</a>
    <span class="sys-text">|</span>
    <a href="/es/" class:list={['lang-btn', { active: lang === 'es' }]} aria-label="Español">ES</a>
    <span class="sys-text sep-v">·</span>
    <a href="/pablo-lerner-cv.pdf" class="lang-btn" download aria-label="Download CV">CV ↓</a>
  </div>

  <span class="coord sys-text">
    LAT:-34.6037 LON:-58.3816 · {sysDate} · NODE:ACTIVE
  </span>
</footer>

<style>
  .status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.45rem 1rem;
    border-top: var(--border);
    background: color-mix(in srgb, var(--bg-void) 90%, black);
    gap: 1rem;
    flex-wrap: wrap;
  }

  .controls {
    display: flex;
    gap: 1.2rem;
  }

  .control {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.63rem;
    letter-spacing: 0.15em;
    color: var(--sand-dim);
  }

  .key {
    border: var(--border);
    padding: 0.05rem 0.3rem;
    font-size: 0.58rem;
    color: var(--sand-dim);
  }

  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .lang-btn {
    font-family: var(--font-mono);
    font-size: 0.63rem;
    letter-spacing: 0.18em;
    color: var(--sand-dim);
    transition: color 0.15s;
  }

  .lang-btn:hover,
  .lang-btn.active {
    color: var(--accent);
  }

  .sep-v {
    opacity: 0.3;
  }

  .coord {
    font-size: 0.57rem;
  }

  @media (max-width: 600px) {
    .coord { display: none; }
    .controls { gap: 0.8rem; }
  }
</style>
