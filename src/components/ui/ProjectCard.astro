---
interface Props {
  name: string;
  desc: string;       // one-line problem statement
  outcome?: string;   // key metric or concrete result
  stack: readonly string[];
  status: string;
  featured?: boolean;
  github: string;
  demo?: string;
}

const { name, desc, outcome, stack, status, featured = false, github, demo } = Astro.props;
---

<li class:list={['project-card', featured && 'featured']}>
  <!-- Top bar: status badge + action links -->
  <div class="card-top">
    <span class="badge">{status}</span>
    <div class="card-actions">
      {demo && (
        <a href={demo} class="action-btn action-demo" target="_blank" rel="noopener noreferrer">
          LIVE DEMO ↗
        </a>
      )}
      <a href={github} class="action-btn" target="_blank" rel="noopener noreferrer" aria-label={`View ${name} on GitHub`}>
        CODE ↗
      </a>
    </div>
  </div>

  <!-- Project title -->
  <h3 class="card-name">{name}</h3>

  <!-- Problem statement (body font for readability) -->
  <p class="card-desc">{desc}</p>

  <!-- Outcome / metric (accent color, only if provided) -->
  {outcome && (
    <div class="card-outcome">
      <span class="outcome-pip">◆</span>
      <span>{outcome}</span>
    </div>
  )}

  <!-- Tech stack tags -->
  <div class="card-stack">
    {stack.map(t => <span class="tag">{t}</span>)}
  </div>
</li>

<script>
  // Card tilt — pointer-following parallax depth effect.
  // Astro dedupes this script: runs once per page even with many cards.
  (function initCardTilt() {
    const html = document.documentElement;

    // Skip on reduced-motion or touch/non-hover devices (these won't change mid-session)
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.matchMedia('(hover: none)').matches) return;

    const MAX_TILT = 7; // degrees

    function applyTilt(card: HTMLElement, e: PointerEvent) {
      if (html.hasAttribute('data-plain')) return; // plain mode: flat card
      const rect = card.getBoundingClientRect();
      const dx = (e.clientX - (rect.left + rect.width  / 2)) / (rect.width  / 2);
      const dy = (e.clientY - (rect.top  + rect.height / 2)) / (rect.height / 2);
      const rotX = -dy * MAX_TILT;
      const rotY =  dx * MAX_TILT;
      // Disable transform transition for instant tracking; keep background/border transitions
      card.style.transition = 'background 0.15s, border-color 0.15s';
      card.style.transform  = `perspective(800px) rotateX(${rotX}deg) rotateY(${rotY}deg) translateY(-2px)`;
    }

    function resetTilt(card: HTMLElement) {
      // Restore full CSS transition so the reset animates smoothly back to flat
      card.style.transition = '';
      card.style.transform  = '';
    }

    document.querySelectorAll<HTMLElement>('.project-card').forEach(card => {
      card.addEventListener('pointermove', e => applyTilt(card, e as PointerEvent), { passive: true });
      card.addEventListener('pointerleave', () => resetTilt(card));
    });
  })();
</script>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.85rem 1rem;
    border: var(--border-mid);
    background: var(--bg-panel);
    position: relative;
    transition: transform 0.15s ease, background 0.15s, border-color 0.15s;
    will-change: transform;
  }

  .project-card:hover {
    transform: translateY(-2px);
    background: var(--bg-surface);
    border-color: var(--ink-mid);
  }

  .project-card.featured {
    border-left: 3px solid var(--accent-bright);
  }

  .project-card.featured:hover {
    border-left-color: var(--accent-bright);
  }

  /* ── Top bar ── */
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .badge {
    font-family: var(--font-mono);
    font-size: 0.56rem;
    letter-spacing: 0.18em;
    padding: 0.1rem 0.45rem;
    border: 1px solid var(--accent);
    color: var(--accent);
    flex-shrink: 0;
  }

  .project-card.featured .badge {
    border-color: var(--accent-bright);
    color: var(--accent-bright);
  }

  .card-actions {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
  }

  .action-btn {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    padding: 0.18rem 0.5rem;
    border: 1px solid var(--ink-mid);
    color: var(--sand-dim);
    text-decoration: none;
    transition: color 0.12s, border-color 0.12s, background 0.12s;
    white-space: nowrap;
  }

  .action-btn:hover {
    color: var(--sand);
    border-color: var(--accent);
  }

  .action-btn.action-demo {
    border-color: var(--accent-bright);
    color: var(--accent-bright);
  }

  .action-btn.action-demo:hover {
    background: var(--accent-bright);
    color: var(--bg-void);
    border-color: var(--accent-bright);
  }

  /* ── Card name ── */
  .card-name {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    letter-spacing: 0.06em;
    color: var(--sand);
    font-weight: 400;
    line-height: 1.3;
  }

  /* ── Problem statement (readable prose) ── */
  .card-desc {
    font-family: var(--font-sans);
    font-size: 0.825rem;
    line-height: 1.6;
    color: var(--sand-muted);
    margin: 0;
  }

  /* ── Outcome metric ── */
  .card-outcome {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--accent-bright);
    padding-top: 0.1rem;
  }

  .outcome-pip {
    font-size: 0.5rem;
    flex-shrink: 0;
  }

  /* ── Stack tags ── */
  .card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 0.1rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    padding: 0.05rem 0.35rem;
    border: var(--border);
    color: var(--sand-dim);
    transition: border-color 0.12s, color 0.12s;
  }

  .project-card:hover .tag {
    border-color: var(--ink-mid);
    color: var(--sand-muted);
  }
</style>
