---
const COUNT = 40;
const litIndexes = new Set([0, 1, 9, 17, 25, 33, 39]);
---

<div class="dot-row" aria-hidden="true">
  {Array.from({ length: COUNT }, (_, i) => (
    <span
      class:list={['dot', { lit: litIndexes.has(i) }]}
      style={`animation-delay: ${i * 28}ms`}
    />
  ))}
</div>

<style>
  .dot-row {
    display: flex;
    gap: 0.38rem;
    padding: 0.4rem 1rem;
    border-bottom: var(--border);
    flex-wrap: nowrap;
    overflow: hidden;
  }

  .dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--ink);
    flex-shrink: 0;
    opacity: 0;
    animation: dot-appear 0.12s ease forwards;
  }

  .dot.lit { background: var(--accent); }

  @keyframes dot-appear {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot { opacity: 1; animation: none; }
  }
</style>
